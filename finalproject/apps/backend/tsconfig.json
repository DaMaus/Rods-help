{
  "compilerOptions": {
    "typeRoots": ["./node_modules/@types", "./types"],
    "rootDir": "./src",
    "outDir": "./dist",
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*", "types/**/*"],
  "exclude": ["node_modules"]
}
